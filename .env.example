# Privy client config. The app ID and client ID are safe to expose to the browser.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Optional public Solana RPC used for displaying USDC balances.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Server-only. Do not prefix with NEXT_PUBLIC and do not commit real secret values.
PRIVY_APP_SECRET=
